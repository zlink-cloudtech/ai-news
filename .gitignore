# 操作系统/工具产生的临时文件
.DS_Store
Thumbs.db
*.swp
*.swo
*~
*.tmp

# 编辑器
.vscode/
.idea/
*.iml

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# 日志（按源单独控制：爬虫日志在 logs/，已 gitignored）
*.log
logs/

# 草稿（按需取消注释）
# 草稿/
# *.draft.md

# 临时抓取缓存（不追踪中间产物；如需保留改 force-add）
data/cache/
data/temp/

# LLM 密钥（配置公开，密钥私密；.secrets.example 入 git 供格式参考）
.secrets
*.secrets
secrets/
config/.secrets

# LLM 调用缓存（按需提交，体积可能较大）
data/llm_cache/

