.venv/
venv/

# v2.3.3 deps self-heal cache（cli.py 运行时写，不入 git）
data/.deps_ok

# uv（v2.0 引入：依赖锁定 + venv 管理）
# - .venv 不入 git（设备/sandbox 各自重建）
# - uv.lock 入 git（依赖锁文件，跨环境保持一致）
.venv/
# uv 缓存目录（不提交）
.uv-cache/

# 日志（按源单独控制：爬虫日志在 logs/，已 gitignored）
*.log
logs/

# 草稿（按需取消注释）
# 草稿/
# *.draft.md

# 临时抓取缓存（不追踪中间产物；如需保留改 force-add）
data/cache/
data/temp/

# LLM 密钥（配置公开，密钥私密；.secrets.example 入 git 供格式参考）
.secrets
*.secrets
secrets/
config/.secrets

# LLM 调用缓存（按需提交，体积可能较大）
data/llm_cache/


# AI 资讯追踪·运行时产物
