# ==========================================
# AI 资讯追踪·LLM 配置（key=value 格式）
# ==========================================
# 复制本文件为 .secrets 再填值
# .secrets 已在 .gitignore
# 优先级：环境变量（AINEWS_LLM_*）> .secrets
#
# 命名规范：
#   - 环境变量解耦，不带 provider 名（如 AINEWS_LLM_API_KEY）
#   - .secrets 带 provider 后缀（AINEWS_LLM_<PROVIDER>_*）
#   - 通用参数用 AINEWS_LLM_<PARAM>
#
# 格式：
#   - # 开头为注释
#   - 空行忽略
#   - KEY=VALUE（VALUE 可用 "..." 或 '...' 包裹；行尾可加  # 注释）
# ==========================================

# ---------- 当前激活的 provider ----------
AINEWS_LLM_PROVIDER=deepseek

# ---------- DeepSeek（推荐：中文好 + 成本低） ----------
AINEWS_LLM_DEEPSEEK_API_KEY=<your-deepseek-api-key>
AINEWS_LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
AINEWS_LLM_DEEPSEEK_MODEL=deepseek-v4-flash

# ---------- OpenAI（备用，注释掉不启用） ----------
# AINEWS_LLM_OPENAI_API_KEY=<your-openai-api-key>
# AINEWS_LLM_OPENAI_BASE_URL=https://api.openai.com/v1
# AINEWS_LLM_OPENAI_MODEL=gpt-4o-mini

# ---------- 自定义中转 / 自部署（示例） ----------
# AINEWS_LLM_CUSTOM_API_KEY=<your-key>
# AINEWS_LLM_CUSTOM_BASE_URL=https://my-proxy.example.com/v1
# AINEWS_LLM_CUSTOM_MODEL=gpt-4o-mini

# ---------- 通用参数（可选，有默认值） ----------
# AINEWS_LLM_MAX_TOKENS=2000
# AINEWS_LLM_TIMEOUT=30
# AINEWS_LLM_TEMPERATURE=0.3
